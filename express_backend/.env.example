# ─── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database (Aiven MySQL) ───────────────────────────────────
DATABASE_URL="none"

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=none
JWT_EXPIRES_IN=7d
REFRESH_SECRET=none
REFRESH_EXPIRES_IN=30d

# ─── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

LIVEKIT_API_KEY=APIxxxxxxxxxx
LIVEKIT_API_SECRET=your_livekit_api_secret_here
LIVEKIT_URL=none

# ─── Chapa Payments (Ethiopian payment gateway) ───────────────
CHAPA_SECRET_KEY=CHAPASK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CHAPA_BASE_URL=none

# ─── Platform Config ──────────────────────────────────────────
PLATFORM_FEE_RATE=0.15
